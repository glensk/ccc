{
  "description": "Global: f+j (hold f, tap j) → jump to ccc TUI tab (ccc jump)",
  "manipulators": [
    {
      "type": "basic",
      "from": {
        "modifiers": { "optional": ["any"] },
        "simultaneous": [{ "key_code": "f" }, { "key_code": "j" }],
        "simultaneous_options": { "key_down_order": "strict" }
      },
      "to": [
        {
          "shell_command": "REPLACE_WITH_ABS_CCC_PATH jump >/dev/null 2>&1 &"
        }
      ],
      "parameters": { "basic.simultaneous_threshold_milliseconds": 500 }
    }
  ]
}
