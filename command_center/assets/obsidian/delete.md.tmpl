## Deleted Jobs Dashboard

This folder is the **trash** for ccc future jobs: the in-note **🗑 Delete job** button (or
`ccc delete-job`) moves a job's markdown file here (keeping its `<cat>/<repo>` substructure) and
soft-deletes its database row, so it disappears from the ccc FUTURE list and from the future
dashboard. Nothing is lost — every trashed file keeps its full frontmatter plus a
`deleted: <date>` stamp, and can be **staged back in** at any time:

- **↩ (first column below)** — restores the job: the row is un-archived and the file moves back
  to its live spot under `{{FUTURE_FOLDER}}/` (`status: registered`, live sync resumes).
- The same **↩ Stage job back in** button sits inside each trashed note.
- CLI: `ccc restore-job <uuid>` or `ccc restore-job -f <file>` (works even if the DB row was
  pruned — the file alone is enough to re-register the job under the same UUID).

**Columns:** **↩** (restore — leftmost) · **Task** (the job's AIM text, linked to its note) ·
**Hash** (the ccc job `id`) · **Repo** · **Deleted** (the day it was trashed) · **Created**.

**This dashboard (`{{DELETE_FOLDER}}/delete.md`) sits inside the folder it queries** but carries
no `session_id` frontmatter, so the query below never lists it. Rows sort newest-deleted first.

**Self-refresh:** the table rebuilds itself on vault changes under `{{DELETE_FOLDER}}/`
(debounced ~2s) and every 30s as a fallback. The muted line under the table shows when it last
rebuilt and how many jobs it found.

```dataviewjs
// ---------------------------------------------------------------------------
// Deleted Jobs Dashboard — dataviewjs, read-only except the ↩ restore button.
// One row per trashed ccc job note under {{DELETE_FOLDER}}/**, newest-deleted
// first. ↩ spawns `ccc restore-job --file <absolute path>` (the file is the
// identity carrier, so restore works even if the DB row was pruned).
// Same self-refresh pattern as future.md / running.md: build()/rebuild() into an
// owned host <div>, debounced vault events + 30s interval, all on dv.component.
// dv eval-s this as a Program (no top-level return) — body wrapped in an IIFE.
// ---------------------------------------------------------------------------
(async () => {
	const A = dv.app;

	const FOLDER = "{{DELETE_FOLDER}}";
	const CCC = "{{CCC_BIN}}";
	const COLUMNS = ["↩", "Task", "Hash", "Repo", "Deleted", "Created"];

	function notify(msg) {
		try {
			if (typeof Notice !== "undefined") {
				new Notice(msg);
				return;
			}
		} catch (e) {
			/* fall through */
		}
		console.log("[deleted-jobs] " + msg);
	}

	if (typeof dv === "undefined" || !dv || !dv.container) return;
	if (!A || !A.vault) {
		dv.paragraph("⚠️ Obsidian app API unavailable — cannot render the live dashboard.");
		return;
	}

	function dateStr(v) {
		if (!v) return "";
		try {
			if (typeof v === "string") return v.trim();
			if (typeof v.toFormat === "function") return v.toFormat("yyyy-MM-dd");
			const d = dv.date(v);
			return d && typeof d.toFormat === "function" ? d.toFormat("yyyy-MM-dd") : String(v);
		} catch (e) {
			return String(v);
		}
	}

	// --- AIM extraction (body read live; slug fallback) ---
	function slugFallback(name) {
		let s = name.replace(/\.md$/i, "");
		s = s.replace(/-[0-9a-f]{4}$/i, "");
		return s.replace(/-/g, " ").trim() || name;
	}
	function extractAim(content, fallbackName) {
		try {
			const m = content.match(/^##\s+AIM\s*$/m);
			if (m) {
				const start = m.index + m[0].length;
				const rest = content.slice(start);
				const nxt = rest.search(/^##\s/m);
				const section = nxt === -1 ? rest : rest.slice(0, nxt);
				const oneLine = section.replace(/\s+/g, " ").trim();
				if (oneLine) return oneLine;
			}
		} catch (e) {
			/* fall through to slug */
		}
		return slugFallback(fallbackName);
	}

	function absPath(vaultRelPath) {
		try {
			if (A.vault.adapter && typeof A.vault.adapter.getFullPath === "function") {
				return A.vault.adapter.getFullPath(vaultRelPath);
			}
			if (A.vault.adapter && A.vault.adapter.basePath) {
				return A.vault.adapter.basePath + "/" + vaultRelPath;
			}
		} catch (e) {
			/* fall through */
		}
		return null;
	}

	function styleCompact(el) {
		el.style.fontSize = "11px";
		el.style.lineHeight = "1.2";
		el.style.padding = "1px 4px";
		el.style.margin = "0";
		el.style.borderRadius = "3px";
		el.style.minHeight = "0";
		el.style.height = "auto";
	}

	function renderCell(container, value, dash = "—") {
		if (value === undefined || value === null || value === "") {
			container.createEl("span", { text: dash });
		} else {
			dv.el("span", value, { container });
		}
	}

	const host = dv.container.createEl("div", { cls: "ccc-djd-host" });

	function stamp(n) {
		const t = new Date();
		const hh = String(t.getHours()).padStart(2, "0");
		const mm = String(t.getMinutes()).padStart(2, "0");
		const ss = String(t.getSeconds()).padStart(2, "0");
		const line = host.createEl("div", { cls: "ccc-djd-stamp" });
		line.setText(`refreshed ${hh}:${mm}:${ss} · ${n} ${n === 1 ? "job" : "jobs"}`);
		line.style.fontSize = "10px";
		line.style.color = "var(--text-muted)";
		line.style.marginTop = "6px";
		line.style.fontStyle = "italic";
	}

	async function build() {
		host.empty();

		let pages;
		try {
			pages = dv.pages(`"${FOLDER}"`);
		} catch (e) {
			host.createEl("p", { text: `⚠️ Failed to query "${FOLDER}": ${e}` });
			stamp(0);
			return;
		}

		const rows = pages
			.where(p => p && p.file)
			.where(p => typeof p.session_id === "string" && p.session_id) // excludes this dashboard
			.array();

		if (rows.length === 0) {
			host.createEl("p", { text: "Trash is empty — no deleted jobs." });
			stamp(0);
			return;
		}

		rows.sort((a, b) => dateStr(b.deleted).localeCompare(dateStr(a.deleted))); // newest first

		const table = host.createEl("table", { cls: "ccc-djd-table" });
		const headRow = table.createEl("thead").createEl("tr");
		COLUMNS.forEach(h => headRow.createEl("th", { text: h }));
		const tbody = table.createEl("tbody");

		for (const p of rows) {
			const tr = tbody.createEl("tr");
			try {
				const path = p.file.path;

				let aim;
				try {
					const tf = A.vault.getAbstractFileByPath(path);
					const content = tf ? await A.vault.cachedRead(tf) : "";
					aim = extractAim(content, p.file.name);
				} catch (e) {
					aim = slugFallback(p.file.name);
				}

				// ↩ — stage this job back into FUTURE via `ccc restore-job --file <abs>`
				// (file-based so it survives a pruned DB row).
				const restoreTd = tr.createEl("td");
				const btn = restoreTd.createEl("button", { text: "↩", cls: "ccc-djd-restore" });
				styleCompact(btn);
				btn.style.cursor = "pointer";
				btn.setAttribute("aria-label", "Stage this job back into FUTURE");
				btn.addEventListener("click", () => {
					const full = absPath(path);
					const cp = window.require?.("child_process");
					if (!cp || !full) {
						notify("restore unavailable");
						return;
					}
					const child = cp.spawn(CCC, ["restore-job", "--file", full]);
					notify(`Staging ${aim} back into FUTURE…`);
					try {
						let errBuf = "";
						if (child.stderr) child.stderr.on("data", d => { errBuf += String(d); });
						child.on("error", e => notify("↩ failed: " + e));
						child.on("exit", code => {
							if (code && code !== 0) {
								notify(`↩ failed (exit ${code}): ${errBuf.trim() || "see console"}`);
							} else if (code === 0) {
								notify("Job staged back into FUTURE ✓");
							}
						});
					} catch (e) {
						/* fire-and-forget acceptable */
					}
				});

				// Task — AIM text, linked to the trashed note
				const taskTd = tr.createEl("td");
				dv.el("span", dv.fileLink(path, false, aim), { container: taskTd });

				// Hash
				const hashTd = tr.createEl("td");
				hashTd.createEl("code", {
					text: p.id !== undefined && p.id !== null && p.id !== "" ? String(p.id) : "—",
				});

				renderCell(tr.createEl("td"), typeof p.repo === "string" ? p.repo : "");
				renderCell(tr.createEl("td"), dateStr(p.deleted));
				renderCell(tr.createEl("td"), dateStr(p.created));
			} catch (e) {
				tr.empty();
				tr.createEl("td", {
					text: `⚠️ ${p.file && p.file.path ? p.file.path : "unknown file"}: ${e}`,
					attr: { colspan: String(COLUMNS.length) },
				});
			}
		}

		stamp(rows.length);
	}

	let building = false;
	let pending = false;
	async function rebuild() {
		if (building) { pending = true; return; }
		building = true;
		try {
			do {
				pending = false;
				await build();
			} while (pending);
		} finally {
			building = false;
		}
	}

	await rebuild();

	let timer = null;
	function schedule() {
		if (timer) window.clearTimeout(timer);
		timer = window.setTimeout(() => { timer = null; rebuild(); }, 2000);
	}
	const SCOPE = FOLDER + "/";
	function inScope(f) {
		return f && typeof f.path === "string" && f.path.startsWith(SCOPE);
	}
	if (dv.component && typeof dv.component.registerEvent === "function") {
		try {
			dv.component.registerEvent(A.metadataCache.on("resolved", schedule));
			dv.component.registerEvent(A.vault.on("modify", f => { if (inScope(f)) schedule(); }));
			dv.component.registerEvent(A.vault.on("create", f => { if (inScope(f)) schedule(); }));
			dv.component.registerEvent(A.vault.on("delete", f => { if (inScope(f)) schedule(); }));
			dv.component.registerInterval(window.setInterval(rebuild, 30000));
		} catch (e) {
			console.log("[deleted-jobs] refresh wiring failed: " + e);
		}
	}
})();
```
