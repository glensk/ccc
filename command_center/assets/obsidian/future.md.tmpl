## Future Jobs Dashboard

```dataviewjs
// ---------------------------------------------------------------------------
// Future Jobs Dashboard — dataviewjs + NATIVE <select>/<button> (no Meta Bind)
//
// One row per ccc "future job" note under {{FUTURE_FOLDER}}/**, sorted by
// category then created date: category rank of repo's "<cat>/<repo>" prefix over
// ["infra","llms","private","sdsc"] (anything not so shaped ranks LAST), then
// `created` DESC within a category. NOTE: ccc's TUI / `ccc ls` additionally HOIST
// a job with an unsatisfied `depends_on` directly under its dependency (indented,
// red |--> marker); that adjacency is TUI/ls-only and is deliberately NOT
// reproduced here (cross-language sort drift) — this dashboard just shows a neutral
// "depends: <hash>" hint per dependent row.
//
// Every editable cell is a plain HTML <select> (or the ▶ <button>); writes go
// through app.fileManager.processFrontMatter(tfile, fm => { fm.<key> = value; }).
// Meta Bind is deliberately NOT used here (the per-file "## Controls" widgets in
// each job note keep using it). Native selects are required for the Cat→Repo
// cascade (options repopulated in JS on Cat change).
//
// Self-refresh: the whole table build is wrapped in build()/rebuild(); it is
// re-run on debounced vault changes (metadataCache "resolved" + vault
// modify/create/delete scoped to the future/ prefix) AND on a 30s interval
// fallback, all registered on dv.component so teardown is automatic. rebuild()
// clears and repopulates a host <div> idempotently and guards against overlap.
//
// dv eval-s this block as a Program, so a top-level `return` throws "Illegal
// return statement" — the whole body is wrapped in (async () => { ... })().
// ---------------------------------------------------------------------------
(async () => {
	const A = dv.app;

	const FOLDER = "{{FUTURE_FOLDER}}";
	const CAT_ORDER = ["infra", "llms", "private", "sdsc"];
	// Mirror of ccc's models.LLM_CHOICES / DEFAULT_LLM — keep in sync when the
	// choice list changes there. opus-4.8-1m = the 1M-context beta form
	// (claude-opus-4-8[1m]); plain opus-4.8 is the 200K default.
	const MODELS = ["fable-5", "opus-4.8", "opus-4.8-1m", "sonnet-5", "haiku-4.5"];
	const DEFAULT_MODEL = "fable-5";
	// Per-model accent: text/border colour + a low-alpha background tint so the
	// select is legible in both light and dark themes (colour carries the signal,
	// the tint just hints). fable-5 → orange, opus-4.8 → green, opus-4.8-1m → teal,
	// sonnet-5 → blue, haiku-4.5 → purple.
	const MODEL_COLORS = {
		"fable-5": { fg: "#d97706", bg: "rgba(217, 119, 6, 0.12)" },
		"opus-4.8": { fg: "#16a34a", bg: "rgba(22, 163, 74, 0.12)" },
		"opus-4.8-1m": { fg: "#0d9488", bg: "rgba(13, 148, 136, 0.12)" },
		"sonnet-5": { fg: "#2563eb", bg: "rgba(37, 99, 235, 0.12)" },
		"haiku-4.5": { fg: "#9333ea", bg: "rgba(147, 51, 234, 0.12)" },
	};
	const JOB_TYPE_OPTIONS = ["claude", "codex", "codex-write"];
	const JOB_TYPE_SYMBOLS = { claude: "✳", codex: "⬡ ✳", "codex-write": "⬡✎ ✳" };
	const COLUMNS = [
		"▶", "Task", "Hash", "Status", "Type",
		"Overseer / Exec", "Cat / Repo", "Start", "Deadline", "Created",
	];

	function notify(msg) {
		try {
			if (typeof Notice !== "undefined") {
				new Notice(msg);
				return;
			}
		} catch (e) {
			/* fall through */
		}
		console.log("[future-jobs] " + msg);
	}

	// --- guard: bail cleanly (never throw) if the context looks unexpected ---
	if (typeof dv === "undefined" || !dv || !dv.container) return;
	if (!A || !A.vault || !A.fileManager) {
		dv.paragraph("⚠️ Obsidian app API unavailable — cannot render the live dashboard.");
		return;
	}

	// --- sort: mirror command_center/core.py _sort_key's is_draft branch ---
	function categoryRank(repo) {
		if (typeof repo !== "string") return CAT_ORDER.length;
		const parts = repo.split("/");
		if (parts.length !== 2) return CAT_ORDER.length; // absolute paths, "other/..." → last
		const idx = CAT_ORDER.indexOf(parts[0]);
		return idx === -1 ? CAT_ORDER.length : idx;
	}
	function createdMs(p) {
		try {
			const d = dv.date(p.created);
			return d && typeof d.toMillis === "function" ? d.toMillis() : 0;
		} catch (e) {
			return 0;
		}
	}
	// A page's FIXED start date as "YYYY-MM-DD" ("" when unset). Dataview auto-parses
	// date-shaped frontmatter values into Luxon DateTimes, so handle object + string.
	function startDateStr(p) {
		const v = p.start_date;
		if (!v) return "";
		try {
			if (typeof v === "string") return v.trim();
			if (typeof v.toFormat === "function") return v.toFormat("yyyy-MM-dd");
			const d = dv.date(v);
			return d && typeof d.toFormat === "function" ? d.toFormat("yyyy-MM-dd") : String(v);
		} catch (e) {
			return String(v);
		}
	}

	// --- vault folder helpers (duck-typed TFolder detection) ---
	function getFolder(path) {
		try {
			if (typeof A.vault.getFolderByPath === "function") {
				const f = A.vault.getFolderByPath(path);
				if (f) return f;
			}
			const af = typeof A.vault.getAbstractFileByPath === "function"
				? A.vault.getAbstractFileByPath(path)
				: null;
			return af && Array.isArray(af.children) ? af : null;
		} catch (e) {
			return null;
		}
	}
	function repoNamesFor(cat) {
		const names = [];
		const folder = getFolder(`{{REPO_TREE}}/${cat}`);
		if (folder && Array.isArray(folder.children)) {
			for (const child of folder.children) {
				if (Array.isArray(child.children)) names.push(child.name); // TFolder, not TFile
			}
		}
		names.sort((x, y) => x.localeCompare(y));
		return names;
	}

	// --- AIM extraction (body read live; slug fallback) ---
	function slugFallback(name) {
		let s = name.replace(/\.md$/i, "");
		s = s.replace(/-[0-9a-f]{4}$/i, ""); // strip trailing 4-hex hash
		return s.replace(/-/g, " ").trim() || name;
	}
	function extractAim(content, fallbackName) {
		try {
			const m = content.match(/^##\s+AIM\s*$/m);
			if (m) {
				const start = m.index + m[0].length;
				const rest = content.slice(start);
				const nxt = rest.search(/^##\s/m); // next heading
				const section = nxt === -1 ? rest : rest.slice(0, nxt);
				const oneLine = section.replace(/\s+/g, " ").trim();
				if (oneLine) return oneLine;
			}
		} catch (e) {
			/* fall through to slug */
		}
		return slugFallback(fallbackName);
	}

	// --- frontmatter write (single chokepoint) ---
	async function writeFm(path, key, value) {
		try {
			const tf = A.vault.getAbstractFileByPath(path);
			if (!tf) {
				notify("⚠️ file not found: " + path);
				return;
			}
			await A.fileManager.processFrontMatter(tf, fm => {
				fm[key] = value;
			});
		} catch (e) {
			notify("⚠️ write failed: " + e);
		}
	}

	// --- compact styling: shrink every native control (selects + ▶ button) ---
	function styleCompact(el) {
		el.style.fontSize = "11px";
		el.style.lineHeight = "1.2";
		el.style.padding = "1px 4px";
		el.style.margin = "0";
		el.style.borderRadius = "3px";
		el.style.minHeight = "0";
		el.style.height = "auto";
	}
	// --- per-model accent: colour text/border + low-alpha tint by current value.
	// Re-runnable — falls back to theme defaults for an unrecognised value. ---
	function applyModelColor(sel) {
		const c = MODEL_COLORS[sel.value];
		if (c) {
			sel.style.color = c.fg;
			sel.style.borderColor = c.fg;
			sel.style.borderStyle = "solid";
			sel.style.borderWidth = "1px";
			sel.style.backgroundColor = c.bg;
			sel.style.fontWeight = "600";
		} else {
			sel.style.color = "";
			sel.style.borderColor = "";
			sel.style.backgroundColor = "";
			sel.style.fontWeight = "";
		}
	}

	// --- neutral chip accent (Type select): same look as the model chips ---
	function applyChip(sel) {
		sel.style.color = "#64748b";
		sel.style.borderColor = "#64748b";
		sel.style.borderStyle = "solid";
		sel.style.borderWidth = "1px";
		sel.style.backgroundColor = "rgba(100, 116, 139, 0.12)";
		sel.style.fontWeight = "600";
	}

	// --- native <select> helpers ---
	function makeSelect(td, options, current) {
		const sel = td.createEl("select", { cls: "ccc-fjd-select" });
		for (const opt of options) {
			const o = sel.createEl("option", { text: opt, value: opt });
			if (opt === current) o.selected = true;
		}
		styleCompact(sel);
		return sel;
	}
	function fillRepoOptions(sel, cat, selected) {
		sel.empty();
		const names = repoNamesFor(cat);
		if (names.length === 0) {
			const o = sel.createEl("option", { text: "(no repos)", value: "" });
			o.selected = true;
			return;
		}
		for (const name of names) {
			const o = sel.createEl("option", { text: name, value: name });
			if (name === selected) o.selected = true;
		}
	}
	function markPending(sel) {
		sel.style.outline = "2px solid var(--color-orange, orange)";
		sel.title = "Pending — pick a repo to move this job (nothing written yet)";
	}
	function clearPending(sel) {
		sel.style.outline = "";
		sel.removeAttribute("title");
	}

	// --- stacked-cell line: a subtle muted prefix label + its control on one row,
	// several rows stacked (block) inside a single <td> (e.g. ovr/exe, cat/repo) ---
	function stackedLine(box, labelText) {
		const line = box.createEl("div");
		line.style.display = "flex";
		line.style.alignItems = "center";
		line.style.gap = "3px";
		if (labelText) {
			const lab = line.createEl("span", { text: labelText });
			lab.style.fontSize = "9px";
			lab.style.color = "var(--text-muted)";
			lab.style.minWidth = "22px";
			lab.style.textTransform = "uppercase";
			lab.style.letterSpacing = "0.03em";
		}
		return line;
	}

	function renderCell(container, value, dash = "—") {
		if (value === undefined || value === null || value === "") {
			container.createEl("span", { text: dash });
		} else {
			dv.el("span", value, { container });
		}
	}

	// --- host container we own: build()/rebuild() clear + repopulate it
	// idempotently (no duplicate tables), so vault-change and interval refreshes
	// never stack a second table on the page. ---
	const host = dv.container.createEl("div", { cls: "ccc-fjd-host" });

	// --- muted "refreshed HH:MM:SS · N jobs" line (staleness visible at a glance) ---
	function stamp(n) {
		const t = new Date();
		const hh = String(t.getHours()).padStart(2, "0");
		const mm = String(t.getMinutes()).padStart(2, "0");
		const ss = String(t.getSeconds()).padStart(2, "0");
		const line = host.createEl("div", { cls: "ccc-fjd-stamp" });
		line.setText(`refreshed ${hh}:${mm}:${ss} · ${n} ${n === 1 ? "job" : "jobs"}`);
		line.style.fontSize = "10px";
		line.style.color = "var(--text-muted)";
		line.style.marginTop = "6px";
		line.style.fontStyle = "italic";
	}

	// --- one full render pass into the (cleared) host ---
	async function build() {
		host.empty();

		let pages;
		try {
			pages = dv.pages(`"${FOLDER}"`);
		} catch (e) {
			host.createEl("p", { text: `⚠️ Failed to query "${FOLDER}": ${e}` });
			stamp(0);
			return;
		}

		const rows = pages
			.where(p => p && p.file)
			.where(p => !p.file.name.startsWith("_")) // dashboard + any "_"-prefixed notes
			.where(p => !p.file.path.split("/").includes("_archive"))
			.array();

		if (rows.length === 0) {
			host.createEl("p", { text: "No future jobs." });
			stamp(0);
			return;
		}

		// Sort by category, then created date (newest first). Dependency HOISTING
		// (a dependent row placed under its dependency) is TUI/ls-only — not done here.
		rows.sort((a, b) => {
			const rankDiff = categoryRank(a.repo) - categoryRank(b.repo);
			if (rankDiff !== 0) return rankDiff;
			return createdMs(b) - createdMs(a); // created DESC (newest first)
		});

		// SCHEDULED split (mirrors ccc's bucket 3): jobs with a fixed start_date sink
		// to a separate section at the very bottom, soonest date first.
		const undated = rows.filter(p => !startDateStr(p));
		const dated = rows.filter(p => !!startDateStr(p));
		dated.sort((a, b) => startDateStr(a).localeCompare(startDateStr(b)));

		// --- build the table by hand (native inputs mounted into <td> cells) ---
		const table = host.createEl("table", { cls: "ccc-fjd-table" });
		const headRow = table.createEl("thead").createEl("tr");
		COLUMNS.forEach(h => headRow.createEl("th", { text: h }));
		const tbody = table.createEl("tbody");

		// One job row (shared by the main list and the bottom SCHEDULED section).
		async function renderJobRow(p) {
			const tr = tbody.createEl("tr");
			try {
				const path = p.file.path;

				// AIM computed up front — used by both the ▶ launch Notice (now the
				// first cell) and the Task cell link.
				let aim;
				try {
					const tf = A.vault.getAbstractFileByPath(path);
					const content = tf ? await A.vault.cachedRead(tf) : "";
					aim = extractAim(content, p.file.name);
				} catch (e) {
					aim = slugFallback(p.file.name);
				}

				// ▶ (FIRST column) — launch this job as a live Claude Code session in a
				// new iTerm TAB via ccc's own launcher (`ccc open-job <session_id>`):
				// opens a fresh tab + types `ccc start-job <id>` into a login shell
				// (full PATH, same as pressing `r` in the ccc TUI). Row vanishes next sync.
				// Deliberately the ONLY action here — ✓ done / 🗑 delete live inside each
				// job note (its Meta Bind button row), not in the dashboard.
				const playTd = tr.createEl("td");
				const btn = playTd.createEl("button", { text: "▶", cls: "ccc-fjd-play" });
				styleCompact(btn); // same compact footprint as the selects
				btn.style.cursor = "pointer";
				btn.setAttribute("aria-label", "Launch this job in a new iTerm tab");
				btn.addEventListener("click", () => {
					const sid = typeof p.session_id === "string" ? p.session_id : "";
					const cp = window.require?.("child_process");
					if (!cp) {
						notify("play unavailable");
						return;
					}
					const child = cp.spawn("{{CCC_BIN}}", ["open-job", sid]);
					notify(`Launching ${aim} in a new iTerm tab…`);
					// Surface a clear error if ccc open-job rejects the id (non-draft /
					// archived) — best-effort; fire-and-forget is acceptable if this fails.
					try {
						let errBuf = "";
						if (child.stderr) child.stderr.on("data", d => { errBuf += String(d); });
						child.on("error", e => notify("▶ failed to launch: " + e));
						child.on("exit", code => {
							if (code && code !== 0) {
								notify(`▶ failed (exit ${code}): ${errBuf.trim() || "see console"}`);
							}
						});
					} catch (e) {
						/* fire-and-forget acceptable */
					}
				});

				// Task — AIM text, linked to the note (name-agnostic; files mid-rename)
				const taskTd = tr.createEl("td");
				dv.el("span", dv.fileLink(path, false, aim), { container: taskTd });

				// Hash — first 4 hex of session_id in a <code> span. NOT frontmatter `id`:
				// Dataview coerces duration-shaped id strings ("035d" = 35 days → renders
				// "P35D"); a full UUID never parses as anything else.
				const hashTd = tr.createEl("td");
				const sid4 = typeof p.session_id === "string" && p.session_id.length >= 4
					? p.session_id.slice(0, 4)
					: "";
				hashTd.createEl("code", {
					text: sid4 || (p.id !== undefined && p.id !== null && p.id !== "" ? String(p.id) : "—"),
				});
				// NEUTRAL "depends: <4-hex>" hint (render-only): this frontmatter-only view
				// can't know the parent's state, so no blocker/red claim — the authoritative
				// red |--> marker lives in the ccc TUI / `ccc ls`. No sort effect.
				const depOn = typeof p.depends_on === "string" ? p.depends_on.trim() : "";
				if (depOn) {
					const depEl = hashTd.createEl("div", { text: "depends: " + depOn.slice(0, 4) });
					depEl.style.fontSize = "10px";
					depEl.style.opacity = "0.6";
					depEl.style.letterSpacing = "-0.2px";
				}

				// Status — plain text
				const statusTd = tr.createEl("td");
				const statusEl = statusTd.createEl("span", {
					text: typeof p.status === "string" && p.status ? p.status : "—",
				});
				statusEl.style.fontSize = "10px";
				statusEl.style.opacity = "0.75";
				statusEl.style.letterSpacing = "-0.2px";

				// Type — symbol + native select writing job_type
				const typeTd = tr.createEl("td");
				const jobType = typeof p.job_type === "string" && p.job_type ? p.job_type : "claude";
				typeTd.createEl("span", { text: (JOB_TYPE_SYMBOLS[jobType] || "?") + " " });
				const typeSel = makeSelect(typeTd, JOB_TYPE_OPTIONS, jobType);
				applyChip(typeSel); // same chip aesthetic as the model selects (neutral slate)
				typeSel.addEventListener("change", () => writeFm(path, "job_type", typeSel.value));

				// Overseer / Exec — two native selects stacked in ONE cell (Overseer
				// above Exec, block, 2px gap; subtle muted ovr/exe prefix labels).
				const modelsTd = tr.createEl("td");
				const modelsBox = modelsTd.createEl("div");
				modelsBox.style.display = "flex";
				modelsBox.style.flexDirection = "column";
				modelsBox.style.gap = "2px";

				// Overseer — writes llm_overseer (missing → fable-5)
				const overLine = stackedLine(modelsBox, "ovr");
				const overVal = typeof p.llm_overseer === "string" && p.llm_overseer ? p.llm_overseer : DEFAULT_MODEL;
				const overSel = makeSelect(overLine, MODELS, overVal);
				applyModelColor(overSel); // colour by current value at render
				overSel.addEventListener("change", () => {
					applyModelColor(overSel); // re-colour immediately on pick
					writeFm(path, "llm_overseer", overSel.value);
				});

				// Exec — writes llm_exec (missing → fable-5)
				const execLine = stackedLine(modelsBox, "exe");
				const execVal = typeof p.llm_exec === "string" && p.llm_exec ? p.llm_exec : DEFAULT_MODEL;
				const execSel = makeSelect(execLine, MODELS, execVal);
				applyModelColor(execSel); // colour by current value at render
				execSel.addEventListener("change", () => {
					applyModelColor(execSel); // re-colour immediately on pick
					writeFm(path, "llm_exec", execSel.value);
				});

				// Cat / Repo — two native selects stacked in ONE cell (Cat above Repo).
				// Cascade unchanged: Cat repopulates Repo options (writes nothing);
				// picking a Repo writes fm.repo = "<cat>/<name>" (single write → file moves).
				const repoVal = typeof p.repo === "string" ? p.repo : "";
				const parts = repoVal.split("/");
				const shaped = parts.length === 2 && CAT_ORDER.includes(parts[0]);
				const curCat = shaped ? parts[0] : "other";
				const curRepoName = shaped ? parts[1] : repoVal;

				const crTd = tr.createEl("td");
				const crBox = crTd.createEl("div");
				crBox.style.display = "flex";
				crBox.style.flexDirection = "column";
				crBox.style.gap = "2px";

				const catLine = stackedLine(crBox, "cat");
				const catOptions = shaped ? CAT_ORDER.slice() : CAT_ORDER.concat(["other"]);
				const catSel = makeSelect(catLine, catOptions, curCat);

				const repoLine = stackedLine(crBox, "repo");
				const repoSel = repoLine.createEl("select", { cls: "ccc-fjd-select" });
				styleCompact(repoSel);
				if (shaped) {
					fillRepoOptions(repoSel, curCat, curRepoName);
				} else {
					// absolute path / unknown shape: keep raw value as the single option
					const o = repoSel.createEl("option", { text: repoVal || "(none)", value: repoVal });
					o.selected = true;
				}

				catSel.addEventListener("change", () => {
					const newCat = catSel.value;
					if (newCat === "other") {
						// restore the raw current value; still writes nothing
						repoSel.empty();
						const o = repoSel.createEl("option", { text: repoVal || "(none)", value: repoVal });
						o.selected = true;
						clearPending(repoSel);
						return;
					}
					fillRepoOptions(repoSel, newCat, null);
					markPending(repoSel); // options changed only — nothing written until a repo is picked
				});
				repoSel.addEventListener("change", () => {
					const name = repoSel.value;
					const cat = catSel.value;
					if (!name || cat === "other") return; // "(no repos)" / "other" → no write
					const newRepo = `${cat}/${name}`;
					clearPending(repoSel);
					writeFm(path, "repo", newRepo);
					notify(`repo → ${newRepo} — this file will move on the next sync`);
				});

				// Start / Deadline / Created — Start shows the FIXED start_date (bold)
				// when set (the SCHEDULED section), else the free-text start_when.
				const startTd = tr.createEl("td");
				const fixed = startDateStr(p);
				if (fixed) {
					startTd.createEl("strong", { text: fixed });
				} else {
					renderCell(startTd, p.start_when);
				}
				renderCell(tr.createEl("td"), p.deadline);
				renderCell(tr.createEl("td"), p.created);
			} catch (e) {
				tr.empty();
				tr.createEl("td", {
					text: `⚠️ ${p.file && p.file.path ? p.file.path : "unknown file"}: ${e}`,
					attr: { colspan: String(COLUMNS.length) },
				});
			}
		}

		for (const p of undated) await renderJobRow(p);
		// SCHEDULED — dated jobs at the very bottom, behind a full-width blue rule
		// (same wording as the ccc TUI section header).
		if (dated.length > 0) {
			const sepTr = tbody.createEl("tr");
			const sepTd = sepTr.createEl("td", {
				attr: { colspan: String(COLUMNS.length) },
			});
			const sep = sepTd.createEl("div", {
				text: "── SCHEDULED — fixed start date (soonest first) ──",
			});
			sep.style.color = "#5fafff";
			sep.style.fontWeight = "700";
			sep.style.fontSize = "11px";
			sep.style.letterSpacing = "0.04em";
			sep.style.whiteSpace = "nowrap";
			for (const p of dated) await renderJobRow(p);
		}

		stamp(rows.length);
	}

	// --- refresh orchestration: single-flight rebuild() coalesces overlapping
	// triggers (building/pending), so a burst of vault events collapses to one
	// extra pass and never runs build() concurrently with itself. ---
	let building = false;
	let pending = false;
	async function rebuild() {
		if (building) { pending = true; return; }
		building = true;
		try {
			do {
				pending = false;
				await build();
			} while (pending);
		} finally {
			building = false;
		}
	}

	// initial render
	await rebuild();

	// debounced (~2s) trigger shared by every event source
	let timer = null;
	function schedule() {
		if (timer) window.clearTimeout(timer);
		timer = window.setTimeout(() => { timer = null; rebuild(); }, 2000);
	}
	const SCOPE = FOLDER + "/";
	function inScope(f) {
		return f && typeof f.path === "string" && f.path.startsWith(SCOPE);
	}
	// Register on dv.component so Obsidian tears the listeners/interval down when
	// the note closes or the block re-renders (no leaks, no duplicate timers).
	if (dv.component && typeof dv.component.registerEvent === "function") {
		try {
			dv.component.registerEvent(A.metadataCache.on("resolved", schedule));
			dv.component.registerEvent(A.vault.on("modify", f => { if (inScope(f)) schedule(); }));
			dv.component.registerEvent(A.vault.on("create", f => { if (inScope(f)) schedule(); }));
			dv.component.registerEvent(A.vault.on("delete", f => { if (inScope(f)) schedule(); }));
			dv.component.registerInterval(window.setInterval(rebuild, 30000)); // fallback
		} catch (e) {
			console.log("[future-jobs] refresh wiring failed: " + e);
		}
	}
})();
```

The `{{FUTURE_FOLDER}}/` folder mirrors every ccc FUTURE job (a not-yet-started Claude Code session)
as one editable markdown file. **This dashboard lives one level up at `{{FUTURE_FOLDER}}.md`** —
outside the queried folder, so it never mirrors itself (and ccc's futuresync, which only scans *under*
`future/`, never sees it). Each row above is one job; edit its fields with the **native dropdowns** and
the change syncs straight into the ccc database — a launchd watcher picks up any frontmatter change
within seconds (and a `repo` change physically **moves** the file). Rows are sorted by category
(`infra` → `llms` → `private` → `sdsc`, anything else last), then newest `created` first within a
category. Dependency **hoisting** (placing a job with an unsatisfied `depends_on` directly under its
dependency, with the red `|-->` marker) is TUI / `ccc ls`-only — here a dependent row just carries a
neutral `depends: <hash>` hint (this frontmatter-only view can't know the dependency's state).

**Fixed start dates (SCHEDULED):** a job whose frontmatter carries a `start_date` (ISO `YYYY-MM-DD`)
sinks into the **SCHEDULED** section at the very bottom of the table (soonest date first), mirroring
ccc's SCHEDULED bucket below FINISHED. Its **Start** cell shows the fixed date in bold instead of the
free-text `start_when`. Launching such a job **before** its date (▶ here, or `r` in the ccc TUI) is
guarded: the new tab's `ccc start-job` warns that the start date is not reached and only proceeds
after an explicit `y`.

**Columns:** **▶** (launch — leftmost) · **Task** (the job's AIM text, linked to its note) ·
**Hash** (the ccc job `id`) · **Status** · **Type** (`job_type`) · **Overseer / Exec** (the
`llm_overseer` / `llm_exec` models, stacked in one cell — Overseer above Exec, default `fable-5`;
`opus-4.8` is the 200K form, `opus-4.8-1m` the 1M-context `claude-opus-4-8[1m]`) ·
**Cat / Repo** (target category above repository, stacked in one cell) · **Start** / **Deadline** /
**Created**.

**Type symbols:** ✳ `claude` (Anthropic implements + reviews) · ⬡ ✳ `codex` (OpenAI implements,
Anthropic reviews) · ⬡✎ ✳ `codex-write` (OpenAI implements + writes, Anthropic reviews).

**Cat → Repo cascade:** changing **Cat** only re-fills the **Repo** dropdown's options and turns it
orange to flag it as pending — it writes **nothing**. Pick a **Repo** to commit `repo = <cat>/<name>`;
the watcher then moves the file (a Notice confirms). A job whose current repo is an absolute path shows
**Cat = other** with the raw path kept as its single Repo option.

**▶ (first column):** launches the job as a live Claude Code session in a new iTerm **tab** via
`ccc open-job <session_id>` — it opens a fresh tab and runs `ccc start-job <id>` in a full login shell
(same as pressing `r` in the ccc TUI; it also creates a window if iTerm has none). The row vanishes on
the next sync — that is expected. Marking a job **done** (✓) or **deleting** it (🗑, into the
[`delete/` trash](delete/delete.md)) is done from the button row *inside each job note* — the
dashboard deliberately carries only ▶.

**Self-refresh:** the table rebuilds itself on vault changes under `{{FUTURE_FOLDER}}/` (debounced
~2s) and every 30s as a fallback, so an open tab never goes stale. The muted line under the table
shows when it last rebuilt and how many jobs it found.
