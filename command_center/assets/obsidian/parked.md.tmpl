## ☾ Parked Jobs Dashboard

```dataviewjs
// ---------------------------------------------------------------------------
// Parked Jobs Dashboard — dataviewjs, READ-ONLY (no <select>, no writes).
//
// A "parked" ccc session is one whose terminal tab/process is GONE but which is
// NOT finished — ccc shows a moon ☾ in its first column. Its transcript is
// preserved and it can be resumed at any time. Parked sessions have no separate
// mirror tree: they live in the SAME {{RUNNING_FOLDER}}/** export tree, only
// distinguished by frontmatter `status == "parked"`.
//
// One row per ccc mirror note under {{RUNNING_FOLDER}}/**, filtered on
// frontmatter `ccc_mirror == "running" AND status == "parked"` (NOT folder
// membership), sorted like ccc's TUI: category rank of the repo's "<cat>/<repo>"
// prefix over ["infra","llms","private","sdsc"] (anything else LAST), then
// `last_response` DESC within a category.
//
// These mirrors are EXPORT-ONLY (ccc DB -> file); this dashboard never writes.
// The only interactive control is the ▶ resume button, which shells out to
// `ccc resume-job <session_id>` to relaunch the session in a new iTerm tab.
//
// Self-refresh: the whole table build is wrapped in build()/rebuild(); it is
// re-run on debounced vault changes (metadataCache "resolved" + vault
// modify/create/delete scoped to the running/ prefix) AND on a 30s interval
// fallback, all registered on dv.component so teardown is automatic. rebuild()
// clears and repopulates a host <div> idempotently and guards against overlap.
//
// dv eval-s this block as a Program, so a top-level `return` throws "Illegal
// return statement" — the whole body is wrapped in (async () => { ... })().
// ---------------------------------------------------------------------------
(async () => {
	const A = dv.app;

	const FOLDER = "{{RUNNING_FOLDER}}";
	const MIRROR_KIND = "running";
	const CAT_ORDER = ["infra", "llms", "private", "sdsc"];
	const CCC = "{{CCC_BIN}}";
	const DEFAULT_MODEL = "fable-5";

	// Per-model accent — the future dashboard's MODEL_COLORS (text/border colour +
	// low-alpha tint, legible in light and dark). fable-5 orange, opus-4.8 green,
	// opus-4.8-1m teal (the 1M-context claude-opus-4-8[1m]), sonnet-5 blue,
	// haiku-4.5 purple. Mirror of ccc's models.LLM_CHOICES — keep in sync.
	const MODEL_COLORS = {
		"fable-5": { fg: "#d97706", bg: "rgba(217, 119, 6, 0.12)" },
		"opus-4.8": { fg: "#16a34a", bg: "rgba(22, 163, 74, 0.12)" },
		"opus-4.8-1m": { fg: "#0d9488", bg: "rgba(13, 148, 136, 0.12)" },
		"sonnet-5": { fg: "#2563eb", bg: "rgba(37, 99, 235, 0.12)" },
		"haiku-4.5": { fg: "#9333ea", bg: "rgba(147, 51, 234, 0.12)" },
	};

	const COLUMNS = [
		"☾", "▶", "Task", "Hash", "Models", "Repo", "Progress", "Next step", "Last response", "Created",
	];

	function notify(msg) {
		try {
			if (typeof Notice !== "undefined") {
				new Notice(msg);
				return;
			}
		} catch (e) {
			/* fall through */
		}
		console.log("[parked-jobs] " + msg);
	}

	// --- guard: bail cleanly (never throw) if the context looks unexpected ---
	if (typeof dv === "undefined" || !dv || !dv.container) return;
	if (!A || !A.vault) {
		dv.paragraph("⚠️ Obsidian app API unavailable — cannot render the live dashboard.");
		return;
	}

	// --- sort: category rank then last_response DESC ---
	function categoryRank(repo) {
		if (typeof repo !== "string") return CAT_ORDER.length;
		const parts = repo.split("/");
		if (parts.length !== 2) return CAT_ORDER.length; // absolute / "other/..." → last
		const idx = CAT_ORDER.indexOf(parts[0]);
		return idx === -1 ? CAT_ORDER.length : idx;
	}
	function dateMs(val) {
		try {
			const d = dv.date(val);
			return d && typeof d.toMillis === "function" ? d.toMillis() : 0;
		} catch (e) {
			return 0;
		}
	}

	// --- text helpers ---
	function slugFallback(name) {
		let s = name.replace(/\.md$/i, "");
		s = s.replace(/-[0-9a-f]{4,8}$/i, ""); // strip trailing 4/8-hex hash
		return s.replace(/-/g, " ").trim() || name;
	}
	// AIM: `## AIM (N)` — the (N) index is stripped by the optional group.
	function extractAim(content, fallbackName) {
		try {
			const m = content.match(/^##\s+AIM(?:\s*\([^)]*\))?\s*$/m);
			if (m) {
				const rest = content.slice(m.index + m[0].length);
				const nxt = rest.search(/^##\s/m);
				const section = nxt === -1 ? rest : rest.slice(0, nxt);
				const oneLine = section.replace(/\s+/g, " ").trim();
				if (oneLine) return oneLine;
			}
		} catch (e) {
			/* fall through to slug */
		}
		return slugFallback(fallbackName);
	}
	// Any `## <heading>` section, bullets flattened to one line.
	function sectionText(content, heading) {
		try {
			const esc = heading.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
			const m = content.match(new RegExp("^##\\s+" + esc + "\\s*$", "m"));
			if (m) {
				const rest = content.slice(m.index + m[0].length);
				const nxt = rest.search(/^##\s/m);
				const section = nxt === -1 ? rest : rest.slice(0, nxt);
				return section.replace(/^[\s>*-]+/gm, "").replace(/\s+/g, " ").trim();
			}
		} catch (e) {
			/* fall through */
		}
		return "";
	}
	function truncate(s, n) {
		return typeof s === "string" && s.length > n ? s.slice(0, n - 1).trimEnd() + "…" : s;
	}

	// --- compact styling for the ▶ button ---
	function styleCompact(el) {
		el.style.fontSize = "12px";
		el.style.lineHeight = "1.2";
		el.style.padding = "1px 5px";
		el.style.margin = "0";
		el.style.borderRadius = "3px";
		el.style.minHeight = "0";
		el.style.height = "auto";
		el.style.cursor = "pointer";
	}
	// --- read-only model chip (static coloured span; no <select>) ---
	function modelChip(line, value) {
		const v = typeof value === "string" && value ? value : DEFAULT_MODEL;
		const chip = line.createEl("span", { text: v });
		chip.style.fontSize = "10px";
		chip.style.padding = "0 4px";
		chip.style.borderRadius = "3px";
		chip.style.borderStyle = "solid";
		chip.style.borderWidth = "1px";
		chip.style.fontWeight = "600";
		const c = MODEL_COLORS[v];
		if (c) {
			chip.style.color = c.fg;
			chip.style.borderColor = c.fg;
			chip.style.backgroundColor = c.bg;
		} else {
			chip.style.color = "var(--text-muted)";
			chip.style.borderColor = "var(--background-modifier-border)";
		}
		return chip;
	}
	// --- stacked prefixed line inside a cell (ovr/exe) ---
	function stackedLine(box, labelText) {
		const line = box.createEl("div");
		line.style.display = "flex";
		line.style.alignItems = "center";
		line.style.gap = "3px";
		if (labelText) {
			const lab = line.createEl("span", { text: labelText });
			lab.style.fontSize = "9px";
			lab.style.color = "var(--text-muted)";
			lab.style.minWidth = "22px";
			lab.style.textTransform = "uppercase";
			lab.style.letterSpacing = "0.03em";
		}
		return line;
	}
	function renderCell(container, value, dash = "—") {
		if (value === undefined || value === null || value === "") {
			container.createEl("span", { text: dash });
		} else {
			container.createEl("span", { text: String(value) });
		}
	}

	// --- host container we own: build()/rebuild() clear + repopulate it
	// idempotently (no duplicate tables) on every refresh. ---
	const host = dv.container.createEl("div", { cls: "ccc-pjd-host" });

	// --- muted "refreshed HH:MM:SS · N jobs" line (staleness visible at a glance) ---
	function stamp(n) {
		const t = new Date();
		const hh = String(t.getHours()).padStart(2, "0");
		const mm = String(t.getMinutes()).padStart(2, "0");
		const ss = String(t.getSeconds()).padStart(2, "0");
		const line = host.createEl("div", { cls: "ccc-pjd-stamp" });
		line.setText(`refreshed ${hh}:${mm}:${ss} · ${n} ${n === 1 ? "job" : "jobs"}`);
		line.style.fontSize = "10px";
		line.style.color = "var(--text-muted)";
		line.style.marginTop = "6px";
		line.style.fontStyle = "italic";
	}

	// --- one full render pass into the (cleared) host ---
	async function build() {
		host.empty();

		let pages;
		try {
			pages = dv.pages(`"${FOLDER}"`);
		} catch (e) {
			host.createEl("p", { text: `⚠️ Failed to query "${FOLDER}": ${e}` });
			stamp(0);
			return;
		}

		// Filter on the queryable markers, NOT folder membership: a mirror in the
		// running/ tree whose status is "parked".
		const rows = pages
			.where(p => p && p.file)
			.where(p => p.ccc_mirror === MIRROR_KIND && p.status === "parked")
			.where(p => !p.file.name.startsWith("_"))
			.array();

		if (rows.length === 0) {
			host.createEl("p", { text: "No parked jobs — every tracked session is live or finished." });
			stamp(0);
			return;
		}

		rows.sort((a, b) => {
			const rankDiff = categoryRank(a.repo) - categoryRank(b.repo);
			if (rankDiff !== 0) return rankDiff;
			return dateMs(b.last_response) - dateMs(a.last_response); // last_response DESC
		});

		// --- build the table by hand ---
		const table = host.createEl("table", { cls: "ccc-pjd-table" });
		const headRow = table.createEl("thead").createEl("tr");
		COLUMNS.forEach(h => headRow.createEl("th", { text: h }));
		const tbody = table.createEl("tbody");

		for (const p of rows) {
			const tr = tbody.createEl("tr");
			try {
				const path = p.file.path;

				// Body read once (AIM + Next step come from it).
				let content = "";
				try {
					const tf = A.vault.getAbstractFileByPath(path);
					content = tf ? await A.vault.cachedRead(tf) : "";
				} catch (e) {
					content = "";
				}
				const aim = extractAim(content, p.file.name);
				const nextStep = sectionText(content, "Next step");

				// ☾ (FIRST column) — grey moon glyph mirroring ccc's TUI parked
				// marker (process gone, resumable).
				const moonTd = tr.createEl("td");
				const moon = moonTd.createEl("span", { text: "☾" });
				moon.style.fontSize = "14px";
				moon.style.color = "#9ca3af";
				moon.title = "parked — process gone, resumable";

				// ▶ (resume column) — resume the parked session in a new iTerm tab
				// via `ccc resume-job <session_id>`.
				const resumeTd = tr.createEl("td");
				const btn = resumeTd.createEl("button", { text: "▶", cls: "ccc-pjd-resume" });
				styleCompact(btn);
				btn.setAttribute("aria-label", "Resume this parked session in a new iTerm tab");
				btn.addEventListener("click", () => {
					const sid = typeof p.session_id === "string" ? p.session_id : "";
					if (!sid) {
						notify("⚠️ no session_id on this note");
						return;
					}
					const cp = window.require?.("child_process");
					if (!cp) {
						notify("resume unavailable (no child_process)");
						return;
					}
					notify(`Resuming ${truncate(aim, 44)} in a new iTerm tab…`);
					try {
						const child = cp.spawn(CCC, ["resume-job", sid]);
						let errBuf = "";
						if (child.stderr) child.stderr.on("data", d => { errBuf += String(d); });
						child.on("error", e => notify("▶ failed to launch: " + e));
						child.on("exit", code => {
							if (code && code !== 0) {
								notify(`▶ resume failed (exit ${code}): ${errBuf.trim() || "see ccc"}`);
							}
						});
					} catch (e) {
						notify("▶ failed: " + e);
					}
				});

				// Task — AIM text, linked to the note (name-agnostic).
				const taskTd = tr.createEl("td");
				dv.el("span", dv.fileLink(path, false, aim), { container: taskTd });

				// Hash — first 4 hex of session_id. NOT frontmatter `id`: Dataview coerces
				// duration-shaped id strings ("035d" = 35 days → renders "P35D"); a full
				// UUID never parses as anything else.
				const hashTd = tr.createEl("td");
				const sid4 = typeof p.session_id === "string" && p.session_id.length >= 4
					? p.session_id.slice(0, 4)
					: "";
				hashTd.createEl("code", {
					text: sid4 || (p.id !== undefined && p.id !== null && p.id !== "" ? String(p.id) : "—"),
				});

				// Models — read-only ran/ovr/exe chips stacked in one cell.
				const modelsTd = tr.createEl("td");
				const modelsBox = modelsTd.createEl("div");
				modelsBox.style.display = "flex";
				modelsBox.style.flexDirection = "column";
				modelsBox.style.gap = "2px";
				// ran — the model that ACTUALLY answered, read from the transcript.
				// Empty / missing key ⇒ a muted em-dash, never a defaulted fable-5 chip.
				const ranLine = stackedLine(modelsBox, "ran");
				const ranVal = typeof p.model === "string" ? p.model.trim() : "";
				if (ranVal) {
					const ranChip = modelChip(ranLine, ranVal);
					ranChip.title = "model that actually answered (from the transcript)";
				} else {
					const ranDash = ranLine.createEl("span", { text: "—" });
					ranDash.style.color = "var(--text-muted)";
					ranDash.title = "not in this mirror yet — resyncs on the next ccc mirror pass";
				}
				// Observed reasoning effort, appended muted after the ran chip (skip if empty).
				const ranEff = typeof p.effort === "string" ? p.effort.trim() : "";
				if (ranEff) {
					const effEl = ranLine.createEl("span", { text: ranEff });
					effEl.style.fontSize = "9px";
					effEl.style.color = "var(--text-muted)";
					effEl.title = "reasoning effort (launch flag / observed)";
				}
				const ovrChip = modelChip(stackedLine(modelsBox, "ovr"), p.llm_overseer);
				ovrChip.title = "job config — may be a default for sessions not launched as ccc jobs";
				const exeChip = modelChip(stackedLine(modelsBox, "exe"), p.llm_exec);
				exeChip.title = "job config — may be a default for sessions not launched as ccc jobs";

				// Repo.
				renderCell(tr.createEl("td"), p.repo);

				// Progress — "n/m" + a tiny percentage.
				const progTd = tr.createEl("td");
				const prog = typeof p.progress === "string" ? p.progress : "";
				const mm = prog.match(/^(\d+)\s*\/\s*(\d+)$/);
				progTd.createEl("span", { text: prog || "—" });
				if (mm) {
					const total = Number(mm[2]);
					const pct = total > 0 ? Math.round((Number(mm[1]) / total) * 100) : 0;
					const pctEl = progTd.createEl("span", { text: ` ${pct}%` });
					pctEl.style.fontSize = "9px";
					pctEl.style.color = "var(--text-muted)";
					pctEl.style.marginLeft = "2px";
				}

				// Next step — truncated ~60 chars, full text in title.
				const nextTd = tr.createEl("td");
				if (nextStep) {
					const nextEl = nextTd.createEl("span", { text: truncate(nextStep, 60) });
					nextEl.style.fontSize = "11px";
					nextEl.title = nextStep;
				} else {
					nextTd.createEl("span", { text: "—" });
				}

				// Last response.
				renderCell(tr.createEl("td"), p.last_response);

				// Created.
				renderCell(tr.createEl("td"), p.created);
			} catch (e) {
				tr.empty();
				tr.createEl("td", {
					text: `⚠️ ${p.file && p.file.path ? p.file.path : "unknown file"}: ${e}`,
					attr: { colspan: String(COLUMNS.length) },
				});
			}
		}

		stamp(rows.length);
	}

	// --- refresh orchestration: single-flight rebuild() coalesces overlapping
	// triggers (building/pending), so a burst of vault events collapses to one
	// extra pass and never runs build() concurrently with itself. ---
	let building = false;
	let pending = false;
	async function rebuild() {
		if (building) { pending = true; return; }
		building = true;
		try {
			do {
				pending = false;
				await build();
			} while (pending);
		} finally {
			building = false;
		}
	}

	// initial render
	await rebuild();

	// debounced (~2s) trigger shared by every event source
	let timer = null;
	function schedule() {
		if (timer) window.clearTimeout(timer);
		timer = window.setTimeout(() => { timer = null; rebuild(); }, 2000);
	}
	const SCOPE = FOLDER + "/";
	function inScope(f) {
		return f && typeof f.path === "string" && f.path.startsWith(SCOPE);
	}
	// Register on dv.component so Obsidian tears the listeners/interval down when
	// the note closes or the block re-renders (no leaks, no duplicate timers).
	if (dv.component && typeof dv.component.registerEvent === "function") {
		try {
			dv.component.registerEvent(A.metadataCache.on("resolved", schedule));
			dv.component.registerEvent(A.vault.on("modify", f => { if (inScope(f)) schedule(); }));
			dv.component.registerEvent(A.vault.on("create", f => { if (inScope(f)) schedule(); }));
			dv.component.registerEvent(A.vault.on("delete", f => { if (inScope(f)) schedule(); }));
			dv.component.registerInterval(window.setInterval(rebuild, 30000)); // fallback
		} catch (e) {
			console.log("[parked-jobs] refresh wiring failed: " + e);
		}
	}
})();
```

A **parked** ccc session is one whose terminal tab/process is **gone** but which
is **not finished** — ccc marks it with a moon **☾** in its first column. Parking
never loses work: the session's transcript is preserved, and it can be **resumed**
at any time (a fresh iTerm tab picks the conversation up exactly where it stopped).

Parked sessions have **no separate mirror tree**. This dashboard is a **filtered
view** over the SAME export-only `{{RUNNING_FOLDER}}/` mirror tree the [running
dashboard](running.md) reads — the rows shown here are simply the mirrors whose
frontmatter `status` is `parked`. Those notes are **export-only**: ccc regenerates
them from its database, so any edit you make there is **overwritten** on the next
sync. To change a job, change the session (in the ccc Terminal User Interface (TUI)
or via `ccc`), never the file. **This dashboard lives one level up at
`01-llm-tasks/parked.md`** — outside the queried folder, so it never mirrors itself
(and it carries no `ccc_mirror` frontmatter, so ccc's mirror cleanup never touches
it either). Rows are sorted exactly like the ccc TUI: category (`infra` → `llms` →
`private` → `sdsc`, anything else last), then most-recent `last_response` first
within a category.

**Columns:** **☾** (parked marker — leftmost, a grey moon mirroring ccc's TUI) ·
**▶** (resume) · **Task** (the job's `## AIM` text, linked to its note) · **Hash**
(the ccc job `id`) · **Models** (three stacked chips: `ran` = the model that actually
answered, read from the transcript, with its reasoning effort shown next to it; `ovr` / `exe` =
the job's configured overseer / executor, which can be database defaults for sessions that were
never launched as ccc future jobs — trust `ran` over them) · **Repo** · **Progress** (checked / total
sub-goals plus a percentage) · **Next step** (truncated) · **Last response** ·
**Created** (the date the session was first tracked). There is no Status column —
every row here is `parked` by construction.

**▶ (resume button):** resumes the session in a new iTerm tab via `ccc resume-job
<session_id>`. If the session turns out to already be live, the command just
**focuses its existing tab** — it never opens a second Read-Eval-Print Loop (REPL)
on the same session. A resumed row **leaves this dashboard** on the next sync,
because its status flips from `parked` back to a live state (and it then reappears
on the [running dashboard](running.md)).

**Model colours** (ccc's `MODEL_COLORS`): 🟠 `fable-5` · 🟢 `opus-4.8` (200K) · 🩵
`opus-4.8-1m` (teal — the 1M-context `claude-opus-4-8[1m]`) · 🔵 `sonnet-5` · 🟣
`haiku-4.5`.

**Self-refresh:** the table rebuilds itself on vault changes under
`{{RUNNING_FOLDER}}/` (debounced ~2s) and every 30s as a fallback, so an open tab
never goes stale. The muted line under the table shows when it last rebuilt and how
many jobs it found.
